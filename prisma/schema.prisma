// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model lxc {
  lxc_unique_id     String   @id @default(uuid())
  lxc_ip            String
  lxc_role          String
  lxc_status        String
  lxc_compose_status String
  created_at        DateTime @default(now())
}

model registry {
  id   String @id @default(uuid())
  name String
  version String
  hosted_on String 
  server_url String?
}

model apiUsers {
  id  String @id @default(uuid())
  fName String
  lName String
  publicPhoto String?
  department String?
  role String?
  personalEmail String
}

model AppUsers {
  id           String   @id @default(uuid())
  username     String   @unique
  displayName  String?
  email        String?  @unique
  role         String?
  avatarUrl    String?
  phone        String?
  isEntraUser  Boolean? @default(false)
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  onboarded    Boolean? @default(false)


  mailboxes    UserMailbox[]
  deviceTokens DeviceToken[]
}

model DeviceToken {
  id        String   @id @default(uuid())
  token     String   @unique // The unique token generated by Firebase on the mobile app
  platform  String   // 'ios' or 'android'
  deviceVersion String?
  deviceName String?
  deviceModelName String?
  deviceBrand String?
  userId    String
  user      AppUsers @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model UserMailbox {
  id                String   @id @default(uuid())

  userId            String
  email             String   // mailbox address (can differ from AppUsers.email)
  

  encryptedPassword String

  isPrimary         Boolean  @default(true)
  provider          String?  // "mailcow", "external", etc.

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              AppUsers @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, email])
}


model ComposeApps {
  id            String   @id @default(uuid())

  name          String   // Jellyfin, Gitea, etc.
  description   String?

  status        String?  // running, stopped, error
  category      String?  // media, dev, networking, backup

  compose_path  String?  // path to docker-compose.yml or repo
  repo_url      String?  // optional git repo

  port          Int?
  url           String?  // dashboard access URL

  created_at    DateTime @default(now())

  infra_id      String?
  infra         Infra?   @relation(fields: [infra_id], references: [id])
}

model Infra {
  id                String   @id @default(uuid())

  node_name        String
  node_ip          String
  node_hostname    String?

  management_url   String?

  role             String?   // e.g. "docker-host", "nas", "proxmox"
  os               String?   // e.g. "Ubuntu 22.04", "Debian"

  total_storage    String?   // keep simple for now (you can normalize later)
  used_storage     String?

  created_at       DateTime  @default(now())

  apps             ComposeApps[]
}
